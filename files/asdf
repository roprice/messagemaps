
async function createInterview(userId, intervieweeName) {
  const intervieweeName = `${firstName} ${lastName}`; // Concatenate the first and last name
  const { data, error } = await supabase
  .from('interviews')
  .insert({
    user_id: userId,
    interviewee_name: intervieweeName,
  });

  if (error) {
    console.error('Error creating interview:', error);
  } else {
    console.log('Interview created successfully:', data);
  }
}


// Get the "Interview me" button
const interviewButton = document.getElementById('InterviewMe');

// Add an event listener to the button
interviewButton.addEventListener('click', () => {
